{
  "manifest_version": 3,
  "name": "SnapShot Pro (Scratch Edition)",
  "version": "1.0",
  "description": "Capture, draw, and crop from scratch.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}